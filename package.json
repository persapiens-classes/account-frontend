{
  "name": "account",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:prod": "ng serve --configuration production",
    "start:code": "ng serve --configuration codespace",
    "build": "ng build",
    "build:prod": "ng build --configuration=production --base-href=/account-frontend/",
    "watch": "ng build --watch --configuration development",
    "test": "vitest -c vitest-unit.config.ts run",
    "test:unit:ui": "vitest -c vitest-unit.config.ts --ui",
    "test:unit:run": "vitest -c vitest-unit.config.ts run",
    "test:unit:watch": "vitest --watch -c vitest-unit.config.ts",
    "clean:unit:coverage": "rimraf coverage/unit",
    "test:unit:coverage": "vitest run --coverage -c vitest-unit.config.ts",
    "clean:unit:ng:coverage": "rimraf coverage/account",
    "test:unit:ng:coverage": "ng test --coverage --watch=false",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write .",
    "lint": "ng lint",
    "lint:sonar": "echo '📊 SonarQube analysis: Check VS Code Problems panel for issues'",
    "lint:all": "pnpm run lint && pnpm run lint:sonar",
    "check-duplication": "pnpm run check-duplication:production && pnpm run check-duplication:tests",
    "check-duplication:verbose": "jscpd --config .jscpdrc.json ./src --verbose",
    "check-duplication:production": "jscpd --config .jscpdrc.json ./src",
    "check-duplication:tests": "jscpd --config .jscpdrc.test.json ./src",
    "check-duplication:all": "pnpm run check-duplication:production && echo '\\n=== Testing duplication in test files ===' && pnpm run check-duplication:tests",
    "quality": "prettier . --check && pnpm run lint && pnpm run test:unit:coverage && pnpm run check-duplication && pnpm run lint:sonar",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:mock:open": "cross-env CYPRESS_USE_MOCK=true cypress open",
    "cypress:mock:run": "cross-env CYPRESS_USE_MOCK=true cypress run",
    "clean:e2e:coverage": "rimraf .nyc_output coverage/e2e",
    "vite:start:instrumented": "cross-env VITE_COVERAGE=true vite --config vite-cypress.config.ts",
    "test:e2e:coverage": "start-server-and-test vite:start:instrumented http://localhost:5173 cypress:mock:run",
    "test:start-server:open": "start-server-and-test vite:start:instrumented http://localhost:5173 cypress:open",
    "test:start-server:run": "start-server-and-test vite:start:instrumented http://localhost:5173 cypress:run",
    "test:start-server:mock:open": "start-server-and-test vite:start:instrumented http://localhost:5173 cypress:mock:open",
    "test:start-server:mock:run": "start-server-and-test vite:start:instrumented http://localhost:5173 cypress:mock:run",
    "merge:coverage": "shx mkdir -p .nyc_output/merged && shx cp coverage/e2e/coverage-final.json .nyc_output/merged/e2e.json && shx cp coverage/unit/coverage-final.json .nyc_output/merged/unit.json && npx nyc merge .nyc_output/merged .nyc_output/merged/coverage-final.json && npx nyc report --reporter=html --reporter=lcov --reporter=json --reporter=text --reporter=text-summary --report-dir=coverage/merged --temp-dir=.nyc_output/merged"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.1",
    "@angular/cdk": "21.2.1",
    "@angular/common": "21.2.1",
    "@angular/compiler": "21.2.1",
    "@angular/core": "21.2.1",
    "@angular/forms": "21.2.1",
    "@angular/platform-browser": "21.2.1",
    "@angular/router": "21.2.1",
    "@primeuix/themes": "2.0.3",
    "@tailwindcss/postcss": "4.2.1",
    "account": "file:",
    "jwt-decode": "4.0.0",
    "postcss": "8.5.8",
    "primeicons": "7.0.0",
    "primeng": "21.1.3",
    "rxjs": "7.8.2",
    "tailwindcss": "4.2.1",
    "tailwindcss-primeui": "0.6.1",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@analogjs/platform": "2.3.1",
    "@angular/build": "21.2.1",
    "@angular/cli": "21.2.1",
    "@angular/compiler-cli": "21.2.1",
    "@cypress/code-coverage": "4.0.1",
    "@cypress/schematic": "5.0.0",
    "@eslint/js": "10.0.1",
    "@types/jsdom": "28.0.0",
    "@types/node": "24.12.0",
    "@vitest/coverage-istanbul": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "4.1.0",
    "angular-cli-ghpages": "3.0.2",
    "angular-eslint": "21.3.0",
    "baseline-browser-mapping": "2.10.7",
    "cross-env": "10.1.0",
    "cypress": "15.11.0",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-sonarjs": "4.0.2",
    "istanbul-lib-coverage": "3.2.2",
    "jscpd": "4.0.8",
    "jsdom": "28.1.0",
    "nyc": "18.0.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "rimraf": "6.1.3",
    "shx": "0.4.0",
    "start-server-and-test": "2.1.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "7.3.1",
    "vite-plugin-istanbul": "8.0.0",
    "vitest": "4.1.0"
  }
}
